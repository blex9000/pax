<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="pax-aurora" name="Pax Aurora" version="1.0">
  <author>Pax</author>
  <description>Aurora — futuristic light theme with iridescent accents</description>
  <metadata><property name="variant">light</property></metadata>

  <color name="base"        value="#fafcfe"/>
  <color name="surface0"    value="#eaf0f8"/>
  <color name="surface1"    value="#e0e8f3"/>
  <color name="surface2"    value="#cfdcee"/>
  <color name="overlay"     value="#7d8aa3"/>
  <color name="text"        value="#1a2740"/>
  <color name="cyan"        value="#00b4d8"/>
  <color name="electric"    value="#0066ff"/>
  <color name="violet"      value="#7e6aff"/>
  <color name="magenta"     value="#c77dff"/>
  <color name="teal"        value="#0095b6"/>
  <color name="green"       value="#06a77d"/>
  <color name="amber"       value="#d68900"/>
  <color name="red"         value="#e63946"/>
  <color name="iris"        value="#5b8def"/>

  <style name="text"                        foreground="text" background="base"/>
  <style name="cursor"                      foreground="magenta"/>
  <style name="selection"                   background="surface2"/>
  <style name="current-line"                background="surface0"/>
  <style name="line-numbers"                foreground="overlay" background="surface0"/>
  <style name="current-line-number"         foreground="cyan" background="surface0"/>
  <style name="bracket-match"               foreground="text" background="surface1" bold="true"/>

  <style name="def:comment"                 foreground="overlay" italic="true"/>
  <style name="def:constant"                foreground="amber"/>
  <style name="def:string"                  foreground="green"/>
  <style name="def:character"               foreground="teal"/>
  <style name="def:number"                  foreground="amber"/>
  <style name="def:boolean"                 foreground="amber"/>
  <style name="def:floating-point"          foreground="amber"/>
  <style name="def:keyword"                 foreground="violet" bold="true"/>
  <style name="def:type"                    foreground="electric"/>
  <style name="def:function"                foreground="cyan"/>
  <style name="def:builtin"                 foreground="red"/>
  <style name="def:identifier"              foreground="text"/>
  <style name="def:preprocessor"            foreground="magenta"/>
  <style name="def:error"                   foreground="red" underline="true"/>
  <style name="def:warning"                 foreground="amber" underline="true"/>
  <style name="def:note"                    foreground="iris" bold="true"/>
  <style name="def:special-char"            foreground="magenta"/>
  <style name="def:operator"                foreground="iris"/>
  <style name="def:statement"               foreground="violet"/>
  <style name="search-match"               background="#rgba(0,180,216,0.25)"/>
</style-scheme>
