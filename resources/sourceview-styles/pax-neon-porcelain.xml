<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="pax-neon-porcelain" name="Pax Neon Porcelain" version="1.0">
  <author>Pax</author>
  <description>Neon Porcelain — synthwave-inverted light theme</description>
  <metadata><property name="variant">light</property></metadata>

  <color name="base"        value="#fffcf9"/>
  <color name="surface0"    value="#f5efe9"/>
  <color name="surface1"    value="#ebe2d8"/>
  <color name="surface2"    value="#ffd6e9"/>
  <color name="overlay"     value="#8a7a80"/>
  <color name="text"        value="#1a0b1f"/>
  <color name="hotpink"     value="#ff2d95"/>
  <color name="cyan"        value="#00c5b8"/>
  <color name="electric"    value="#00b4d8"/>
  <color name="violet"      value="#c77dff"/>
  <color name="amber"       value="#d68900"/>
  <color name="green"       value="#00c896"/>
  <color name="red"         value="#e63946"/>
  <color name="dim"         value="#b8a89e"/>

  <style name="text"                        foreground="text" background="base"/>
  <style name="cursor"                      foreground="hotpink"/>
  <style name="selection"                   background="surface2"/>
  <style name="current-line"                background="surface0"/>
  <style name="line-numbers"                foreground="overlay" background="surface0"/>
  <style name="current-line-number"         foreground="hotpink" background="surface0"/>
  <style name="bracket-match"               foreground="text" background="surface1" bold="true"/>

  <style name="def:comment"                 foreground="dim" italic="true"/>
  <style name="def:constant"                foreground="amber"/>
  <style name="def:string"                  foreground="green"/>
  <style name="def:character"               foreground="cyan"/>
  <style name="def:number"                  foreground="amber"/>
  <style name="def:boolean"                 foreground="amber"/>
  <style name="def:floating-point"          foreground="amber"/>
  <style name="def:keyword"                 foreground="hotpink" bold="true"/>
  <style name="def:type"                    foreground="violet"/>
  <style name="def:function"                foreground="electric"/>
  <style name="def:builtin"                 foreground="red"/>
  <style name="def:identifier"              foreground="text"/>
  <style name="def:preprocessor"            foreground="cyan"/>
  <style name="def:error"                   foreground="red" underline="true"/>
  <style name="def:warning"                 foreground="amber" underline="true"/>
  <style name="def:note"                    foreground="cyan" bold="true"/>
  <style name="def:special-char"            foreground="violet"/>
  <style name="def:operator"                foreground="cyan"/>
  <style name="def:statement"               foreground="hotpink"/>
  <style name="search-match"               background="#rgba(255,45,149,0.22)"/>
</style-scheme>
