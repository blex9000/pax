<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="pax-catppuccin-latte" name="Pax Catppuccin Latte" version="1.0">
  <author>Pax</author>
  <description>Catppuccin Latte for Pax editor</description>
  <metadata><property name="variant">light</property></metadata>

  <color name="base"       value="#eff1f5"/>
  <color name="mantle"     value="#e6e9ef"/>
  <color name="surface0"   value="#ccd0da"/>
  <color name="surface1"   value="#bcc0cc"/>
  <color name="overlay0"   value="#9ca0b0"/>
  <color name="text"       value="#4c4f69"/>
  <color name="red"        value="#d20f39"/>
  <color name="green"      value="#40a02b"/>
  <color name="yellow"     value="#df8e1d"/>
  <color name="blue"       value="#1e66f5"/>
  <color name="mauve"      value="#8839ef"/>
  <color name="teal"       value="#179299"/>
  <color name="peach"      value="#fe640b"/>
  <color name="sky"        value="#04a5e5"/>
  <color name="pink"       value="#ea76cb"/>
  <color name="lavender"   value="#7287fd"/>

  <style name="text"                        foreground="text" background="base"/>
  <style name="cursor"                      foreground="lavender"/>
  <style name="selection"                   background="surface0"/>
  <style name="current-line"                background="mantle"/>
  <style name="line-numbers"                foreground="overlay0" background="mantle"/>
  <style name="current-line-number"         foreground="lavender" background="mantle"/>
  <style name="bracket-match"               foreground="text" background="surface0" bold="true"/>

  <style name="def:comment"                 foreground="overlay0" italic="true"/>
  <style name="def:constant"                foreground="peach"/>
  <style name="def:string"                  foreground="green"/>
  <style name="def:character"               foreground="teal"/>
  <style name="def:number"                  foreground="peach"/>
  <style name="def:boolean"                 foreground="peach"/>
  <style name="def:floating-point"          foreground="peach"/>
  <style name="def:keyword"                 foreground="mauve" bold="true"/>
  <style name="def:type"                    foreground="yellow"/>
  <style name="def:function"                foreground="blue"/>
  <style name="def:builtin"                 foreground="red"/>
  <style name="def:identifier"              foreground="text"/>
  <style name="def:preprocessor"            foreground="pink"/>
  <style name="def:error"                   foreground="red" underline="true"/>
  <style name="def:warning"                 foreground="yellow" underline="true"/>
  <style name="def:note"                    foreground="teal" bold="true"/>
  <style name="def:special-char"            foreground="pink"/>
  <style name="def:operator"                foreground="sky"/>
  <style name="def:statement"               foreground="mauve"/>
  <style name="search-match"               background="#ff8c00" foreground="#000000"/>
</style-scheme>
