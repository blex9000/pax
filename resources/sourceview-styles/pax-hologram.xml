<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="pax-hologram" name="Pax Hologram" version="1.0">
  <author>Pax</author>
  <description>Hologram — sci-fi light theme with mint/magenta duality</description>
  <metadata><property name="variant">light</property></metadata>

  <color name="base"        value="#fbfcff"/>
  <color name="surface0"    value="#e8ecf7"/>
  <color name="surface1"    value="#dde2f0"/>
  <color name="surface2"    value="#cce8e0"/>
  <color name="overlay"     value="#7a8298"/>
  <color name="text"        value="#0a0e1f"/>
  <color name="mint"        value="#00c4a3"/>
  <color name="magenta"     value="#ff3c92"/>
  <color name="electric"    value="#00b4d8"/>
  <color name="violet"      value="#a07aff"/>
  <color name="amber"       value="#d68900"/>
  <color name="green"       value="#06a77d"/>
  <color name="red"         value="#e63946"/>
  <color name="dim"         value="#a0a8b8"/>

  <style name="text"                        foreground="text" background="base"/>
  <style name="cursor"                      foreground="magenta"/>
  <style name="selection"                   background="surface2"/>
  <style name="current-line"                background="surface0"/>
  <style name="line-numbers"                foreground="overlay" background="surface0"/>
  <style name="current-line-number"         foreground="magenta" background="surface0"/>
  <style name="bracket-match"               foreground="text" background="surface1" bold="true"/>

  <style name="def:comment"                 foreground="dim" italic="true"/>
  <style name="def:constant"                foreground="amber"/>
  <style name="def:string"                  foreground="green"/>
  <style name="def:character"               foreground="mint"/>
  <style name="def:number"                  foreground="amber"/>
  <style name="def:boolean"                 foreground="amber"/>
  <style name="def:floating-point"          foreground="amber"/>
  <style name="def:keyword"                 foreground="magenta" bold="true"/>
  <style name="def:type"                    foreground="violet"/>
  <style name="def:function"                foreground="electric"/>
  <style name="def:builtin"                 foreground="red"/>
  <style name="def:identifier"              foreground="text"/>
  <style name="def:preprocessor"            foreground="mint"/>
  <style name="def:error"                   foreground="red" underline="true"/>
  <style name="def:warning"                 foreground="amber" underline="true"/>
  <style name="def:note"                    foreground="mint" bold="true"/>
  <style name="def:special-char"            foreground="mint"/>
  <style name="def:operator"                foreground="mint"/>
  <style name="def:statement"               foreground="magenta"/>
  <style name="search-match"               background="#rgba(0,255,208,0.25)"/>
</style-scheme>
