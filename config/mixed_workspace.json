{
    "name": "mixed-demo",
    "layout": {
        "type": "hsplit",
        "children": [
            {
                "type": "vsplit",
                "children": [
                    { "type": "panel", "id": "term1" },
                    { "type": "panel", "id": "term2" }
                ],
                "ratios": [0.6, 0.4]
            },
            {
                "type": "vsplit",
                "children": [
                    { "type": "panel", "id": "notes" },
                    { "type": "panel", "id": "browser" }
                ],
                "ratios": [0.5, 0.5]
            }
        ],
        "ratios": [0.6, 0.4]
    },
    "panels": [
        {
            "id": "term1",
            "name": "Shell",
            "panel_type": { "type": "terminal" },
            "groups": ["dev"]
        },
        {
            "id": "term2",
            "name": "Build",
            "panel_type": { "type": "terminal" },
            "startup_commands": ["echo 'Ready to build'"],
            "groups": ["dev"],
            "record_output": true
        },
        {
            "id": "notes",
            "name": "Notes",
            "panel_type": { "type": "markdown", "file": "README.md" }
        },
        {
            "id": "browser",
            "name": "Dashboard",
            "panel_type": { "type": "browser", "url": "https://example.com" }
        }
    ],
    "groups": [
        {
            "name": "dev",
            "color": "green",
            "blocked_patterns": []
        }
    ],
    "alerts": [
        {
            "pattern": "(?i)error|panic",
            "scope": "all",
            "actions": [{ "border_color": "red" }, "desktop_notification"]
        }
    ]
}
