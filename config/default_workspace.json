{
    "name": "default",
    "layout": {
        "type": "hsplit",
        "children": [
            {
                "type": "vsplit",
                "children": [
                    { "type": "panel", "id": "main" },
                    { "type": "panel", "id": "logs" }
                ],
                "ratios": [0.7, 0.3]
            },
            { "type": "panel", "id": "side" }
        ],
        "ratios": [0.6, 0.4]
    },
    "panels": [
        {
            "id": "main",
            "name": "Main",
            "panel_type": { "type": "terminal" },
            "startup_commands": [],
            "groups": ["all"],
            "record_output": false
        },
        {
            "id": "logs",
            "name": "Logs",
            "panel_type": { "type": "terminal" },
            "startup_commands": [],
            "groups": ["all"],
            "record_output": true
        },
        {
            "id": "side",
            "name": "Side",
            "panel_type": { "type": "terminal" },
            "startup_commands": [],
            "groups": ["all"],
            "record_output": false
        }
    ],
    "groups": [
        {
            "name": "all",
            "color": "yellow",
            "blocked_patterns": ["^rm\\s+-rf\\s+/", "^shutdown", "^reboot"],
            "confirm_before_execute": false
        }
    ],
    "alerts": [
        {
            "pattern": "(?i)error|fail|panic",
            "scope": "all",
            "actions": [
                { "border_color": "red" },
                "desktop_notification"
            ]
        }
    ],
    "settings": {
        "default_shell": "/bin/bash",
        "scrollback_lines": 10000
    }
}
